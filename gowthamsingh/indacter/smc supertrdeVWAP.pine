//@version=5
indicator('SMC + Supertrend + VWAP [Combined]', 'SMC-ST-VWAP', overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 500, max_polylines_count = 100)
//---------------------------------------------------------------------------------------------------------------------}
//CONSTANTS & STRINGS & INPUTS
//---------------------------------------------------------------------------------------------------------------------{
BULLISH_LEG                     = 1
BEARISH_LEG                     = 0


# ═══════════════════════════════════════════════
# Gautam Singh Model — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to /home/ubuntu/Gautamsinghmodle/.env
# and fill in your actual values

DJANGO_ENV=production
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_50_CHAR_STRING
DJANGO_ALLOWED_HOSTS=YOUR_EC2_PUBLIC_IP,YOUR_DOMAIN.com

# ─── Razorpay ───
DEMO_MODE=True
RAZORPAY_KEY_ID=rzp_test_REPLACE
RAZORPAY_KEY_SECRET=REPLACE
RAZORPAY_WEBHOOK_SECRET=REPLACE

# ─── Google OAuth (optional) ───
GOOGLE_CLIENT_ID=REPLACE
GOOGLE_CLIENT_SECRET=REPLACE

# ─── SSL (set to False if not using HTTPS yet) ───
SECURE_SSL_REDIRECT=False
